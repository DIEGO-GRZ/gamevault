# ─────────────────────────────────────────────
#  GAMEVAULT — Variables de Entorno
#  Copia este archivo como .env y rellena los valores
#  NUNCA subas el .env real a Git
# ─────────────────────────────────────────────

# ── Twitch / IGDB (Diego) ─────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
IGDB_BASE_URL=https://api.igdb.com/v4

# ── IA — Gemini (Diego) ───────────────────────
GEMINI_API_KEY=

# ── Base de Datos (Ricardo) ───────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=gamevault
DB_USER=gamevault
DB_PASSWORD=secret

# ── JWT (Andrés) ──────────────────────────────
JWT_SECRET=pon_aqui_un_string_largo_y_secreto
JWT_EXPIRES_IN=7d

# ── Servidor (Andrés) ─────────────────────────
PORT=3000
NODE_ENV=development